# CamNet environment.
# Copy this file to ".env"  (cp .env.example .env)
#
# Everything can be left blank / as-is and the demo still runs fully offline
# using a deterministic heuristic "mock" for chat + threat scoring.
#
# >>> TO ENABLE REAL GOOGLE GEMINI: paste your key on the line below. <<<
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# Optional: override the model (default is gemini-2.0-flash).
GEMINI_MODEL=gemini-2.0-flash
